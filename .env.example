# Arc Testnet RPC (official Circle endpoint)
ARC_TESTNET_RPC_URL="https://rpc.testnet.arc.network"

# Deployer private key (hex with 0x prefix). NEVER commit this file.
PRIVATE_KEY="0xYOUR_PRIVATE_KEY_HERE"

# Address that receives the tithe (your church / missions / benevolence wallet)
TITHE_RECIPIENT="0xYOUR_TITHE_RECIPIENT_ADDRESS"

# Optional overrides
TITHE_NAME="Tithe Token"
TITHE_SYMBOL="TITHE"
TITHE_INITIAL_SUPPLY="1000000"
TITHE_BPS="1000"
